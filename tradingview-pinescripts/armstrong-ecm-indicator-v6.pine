// @version=6
// @title Armstrong ECM Cycle Indicator v1.0
// @description Martin Armstrong's Economic Confidence Model (8.6-year pi cycle) for crypto and FX trading
// @author impro58
// @category Trend Analysis

indicator("Armstrong ECM Cycle", shorttitle="ECM", overlay=true)

// ============================================
// ARMSTRONG ECM CYCLE INDICATOR v6
// Based on Economic Confidence Model (pi × 1000 days = 8.6 years)
// ============================================

// Input parameters
grp_cycle = "ECM Cycle Settings"
startDate = input.time(timestamp("2024-02-01 00:00 +0000"), "ECM Start Date (Last Major Low)", group=grp_cycle)
showDaily = input.bool(true, "Show Daily pi Cycles", group=grp_cycle)
showWeekly = input.bool(true, "Show Weekly pi Cycles", group=grp_cycle)
showWave = input.bool(false, "Show ECM Wave (separate scale)", group=grp_cycle)

grp_display = "Display Settings"
lineWidth = input.int(2, "Line Width", minval=1, maxval=4, group=grp_display)

// ============================================
// CYCLE CALCULATIONS
// ============================================

// Armstrong's pi-based time units
pi = 3.14159
dailyCycle = pi * 1000 / 365.25 * 0.01    // ~8.6 days (for crypto)
weeklyCycle = pi * 1000 / 52.1775 * 0.1   // ~8.6 weeks

// Time since ECM start in days
timeSince = (time - startDate) / 86400000.0

// ============================================
// ECM TURN DATE CALCULATIONS
// ============================================

ecmTurn(cycleLength) =>
    periods = math.floor(timeSince / cycleLength)
    nextTurn = startDate + ((periods + 1) * cycleLength * 86400)
    daysToTurn = (nextTurn - time) / 86400000
    [daysToTurn, periods]

[dailyTo, dailyCount] = ecmTurn(dailyCycle)
[weeklyTo, weeklyCount] = ecmTurn(weeklyCycle)

// ============================================
// BACKGROUND ALERTS
// ============================================

ecmProximity = math.min(math.abs(dailyTo), math.abs(weeklyTo))

bgColor = if ecmProximity < 1
    color.new(color.red, 90)
else if ecmProximity < 3
    color.new(color.orange, 90)
else if ecmProximity < 7
    color.new(color.yellow, 90)
else
    na

bgcolor(showDaily and not na(bgColor) ? bgColor : na, title="ECM Proximity Alert")

// ============================================
// ECM WAVE - Scaled to price
// ============================================

ecmWave = math.sin(2 * pi * timeSince / (dailyCycle * 20))

// Scale wave to match price chart
atrValue = ta.atr(14)
ecmWaveScaled = close + (ecmWave * atrValue * 2)

plot(showWave ? ecmWaveScaled : na, title="ECM Wave", color=color.new(color.blue, 50), linewidth=lineWidth)

// ============================================
// INFORMATION PANEL
// ============================================

var table infoPanel = table.new(position.top_right, 2, 6, 
     bgcolor=color.new(color.black, 10), 
     border_width=1, 
     border_color=color.gray)

if barstate.islast
    table.cell(infoPanel, 0, 0, "ECM Cycle Status", text_color=color.white, text_size=size.normal)
    table.cell(infoPanel, 1, 0, "", text_color=color.white, text_size=size.normal)
    
    dailyStatus = if dailyTo < 0
        "Past"
    else if dailyTo < 3
        "IMMINENT"
    else
        str.tostring(dailyTo, "#.1")
    table.cell(infoPanel, 0, 1, "Daily pi:", text_color=color.gray, text_size=size.small)
    table.cell(infoPanel, 1, 1, dailyStatus, text_color=dailyTo < 3 ? color.red : color.gray, text_size=size.small)
    
    weeklyStatus = if weeklyTo < 0
        "Past"
    else if weeklyTo < 7
        "WATCH"
    else
        str.tostring(weeklyTo, "#.1")
    table.cell(infoPanel, 0, 2, "Weekly pi:", text_color=color.gray, text_size=size.small)
    table.cell(infoPanel, 1, 2, weeklyStatus, text_color=weeklyTo < 7 ? color.orange : color.gray, text_size=size.small)
    
    phase = if ecmWave > 0.5
        "Expansion"
    else if ecmWave < -0.5
        "Contraction"
    else
        "Transition"
    phaseColor = if ecmWave > 0.5
        color.green
    else if ecmWave < -0.5
        color.red
    else
        color.gray
    table.cell(infoPanel, 0, 3, "Phase:", text_color=color.gray, text_size=size.small)
    table.cell(infoPanel, 1, 3, phase, text_color=phaseColor, text_size=size.small)
    
    table.cell(infoPanel, 0, 4, "Days Since:", text_color=color.gray, text_size=size.small)
    table.cell(infoPanel, 1, 4, str.tostring(int(timeSince)), text_color=color.gray, text_size=size.small)
    
    table.cell(infoPanel, 0, 5, "ECM Count:", text_color=color.gray, text_size=size.small)
    table.cell(infoPanel, 1, 5, str.tostring(dailyCount), text_color=color.gray, text_size=size.small)

// ============================================
// ALERTS
// ============================================

alertcondition(dailyTo >= 0 and dailyTo < 1, title="Daily pi Turn", message="Armstrong ECM Daily pi turn approaching")
alertcondition(weeklyTo >= 0 and weeklyTo < 3, title="Weekly pi Turn", message="Armstrong ECM Weekly pi turn approaching")

// ============================================
// PLOT MARKERS
// ============================================

plotshape(showDaily and dailyTo >= 0 and dailyTo < 1, 
     title="Daily pi", 
     location=location.top, 
     color=color.red, 
     style=shape.triangleup, 
     size=size.small)

plotshape(showWeekly and weeklyTo >= 0 and weeklyTo < 3, 
     title="Weekly pi", 
     location=location.top, 
     color=color.orange, 
     style=shape.diamond, 
     size=size.small)
